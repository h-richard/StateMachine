<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="stateMachine" nsURI="http://www.example.org/stateMachine" nsPrefix="stateMachine">
  <eClassifiers xsi:type="ecore:EClass" name="StateMachine" eSuperTypes="//CompositeState">
    <eAnnotations source="Xmod_main"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="events" upperBound="-1" eType="//Event" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="transitions" upperBound="-1" eType="//Transition" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="State">
    <eAnnotations source="Xmod_exec"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="container" eType="//CompositeState" eOpposite="//CompositeState/states"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="isActive" lowerBound="1" defaultValueLiteral="false">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="actions" upperBound="-1" eType="//Xmod_Action" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="CompositeState" eSuperTypes="//State">
    <eStructuralFeatures xsi:type="ecore:EReference" name="states" lowerBound="1" upperBound="-1" eType="//State" containment="true" eOpposite="//State/container"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="initialState" lowerBound="1" eType="//InitialState"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="historyState" eType="//HistoryState"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="PseudoState" abstract="true" eSuperTypes="//State">
    <eStructuralFeatures xsi:type="ecore:EReference" name="referencedState" eType="//State"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="InitialState" eSuperTypes="//PseudoState"/>
  <eClassifiers xsi:type="ecore:EClass" name="HistoryState" eSuperTypes="//PseudoState"/>
  <eClassifiers xsi:type="ecore:EClass" name="Transition">
    <eAnnotations source="Xmod_exec"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="event" lowerBound="1" eType="//Event"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="source" lowerBound="1" eType="//State"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="target" lowerBound="1" eType="//State"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="actions" upperBound="-1" eType="//Xmod_Action" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Event">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Xmod_Exception">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="kind" lowerBound="1" eType="//Xmod_ExceptionKind"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="filter">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="reaction" lowerBound="1" eType="//Xmod_ExceptionReaction"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="calledOperation" eType="//Xmod_Operation" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Xmod_Action">
    <eOperations name="execute" lowerBound="1" eType="//Xmod_ExceptionReaction"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="operations" lowerBound="1" upperBound="-1" eType="//Xmod_Operation" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Xmod_Operation">
    <eOperations name="callOperation" lowerBound="1" eType="//Xmod_Exception"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectTag" lowerBound="1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="parametersTag" upperBound="-1">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="returnTag">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="exceptions" upperBound="-1" eType="//Xmod_Exception" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Xmod_ExceptionReaction">
    <eLiterals name="continue"/>
    <eLiterals name="skip" value="1"/>
    <eLiterals name="exit" value="2"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Xmod_Element" abstract="true">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="xmod_id">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Xmod_ExceptionKind">
    <eLiterals name="ok"/>
    <eLiterals name="unknownNamespace" value="1"/>
    <eLiterals name="objectNotFound" value="2"/>
    <eLiterals name="methodNotFound" value="3"/>
    <eLiterals name="parametersNotMatching" value="4"/>
    <eLiterals name="returnTypeNotMatching" value="5"/>
    <eLiterals name="methodException" value="6"/>
    <eLiterals name="other" value="7"/>
  </eClassifiers>
</ecore:EPackage>
